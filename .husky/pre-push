#!/bin/bash
# Pre-push hook - 在推送前检查代码质量

set -e

echo "🧪 运行 pre-push 检查..."
echo ""

# 颜色定义
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

FAILED=0

# ============================================================
# 1. 前端完整测试
# ============================================================
echo "🧪 运行前端完整测试..."

if [ -d "frontend" ]; then
    cd frontend
    
    # 安装依赖
    npm ci > /dev/null 2>&1
    
    # 运行 Lint
    if npm run lint > /dev/null 2>&1; then
        echo -e "${GREEN}✅ 前端 Lint 通过${NC}"
    else
        echo -e "${RED}❌ 前端 Lint 失败${NC}"
        FAILED=1
    fi
    
    # 运行构建
    if npm run build > /dev/null 2>&1; then
        echo -e "${GREEN}✅ 前端构建通过${NC}"
    else
        echo -e "${RED}❌ 前端构建失败${NC}"
        FAILED=1
    fi
    
    # 运行测试
    if npm run test:coverage > /dev/null 2>&1; then
        echo -e "${GREEN}✅ 前端测试通过${NC}"
    else
        echo -e "${RED}❌ 前端测试失败${NC}"
        FAILED=1
    fi
    
    cd ..
else
    echo -e "${YELLOW}⚠️  前端目录不存在${NC}"
fi

echo ""

# ============================================================
# 2. 后端完整测试
# ============================================================
echo "🧪 运行后端完整测试..."

if [ -d "backend" ]; then
    cd backend
    
    # 安装依赖
    pip install -e . > /dev/null 2>&1
    
    # 运行 Ruff 检查
    if python3 -m ruff check . > /dev/null 2>&1; then
        echo -e "${GREEN}✅ 后端 Ruff 检查通过${NC}"
    else
        echo -e "${RED}❌ 后端 Ruff 检查失败${NC}"
        FAILED=1
    fi
    
    # 运行测试
    if python3 -m pytest tests/ -v > /dev/null 2>&1; then
        echo -e "${GREEN}✅ 后端测试通过${NC}"
    else
        echo -e "${RED}❌ 后端测试失败${NC}"
        FAILED=1
    fi
    
    cd ..
else
    echo -e "${YELLOW}⚠️  后端目录不存在${NC}"
fi

echo ""

# ============================================================
# 3. 结果
# ============================================================
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✅ 所有检查通过，允许推送${NC}"
    exit 0
else
    echo -e "${RED}❌ 检查失败，请修复问题后重试${NC}"
    echo ""
    echo "如果需要跳过检查，使用："
    echo "  git push --no-verify"
    exit 1
fi
